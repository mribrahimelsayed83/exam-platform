PORT=5000
DATABASE_URL=postgresql://postgres:your_password@localhost:5432/exam_platform
JWT_SECRET=your_super_secret_key_change_this_in_production
JWT_EXPIRES_IN=7d

# Teacher default credentials (used only on first DB seed)
TEACHER_USERNAME=teacher
TEACHER_PASSWORD=teacher123
TEACHER_NAME=المدرس

# Resend Email Service
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxx
FROM_EMAIL=noreply@yourdomain.com
# لو مش عندك domain، استخدم: onboarding@resend.dev (للتجربة بس)
FRONTEND_URL=https://exam-platform-nu.vercel.app

# PayMob Payment Gateway
# سجّل على paymob.com وخد البيانات دي من لوحة التحكم
PAYMOB_API_KEY=your_paymob_api_key_here
PAYMOB_INTEGRATION_ID=your_integration_id_here   # رقم الـ integration (كارت/فوري/محافظ)
PAYMOB_IFRAME_ID=your_iframe_id_here             # رقم الـ iframe من PayMob dashboard
PAYMOB_HMAC_SECRET=your_hmac_secret_here         # من Settings → Security → HMAC Secret
